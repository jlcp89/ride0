{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$CLAUDE_FILE_PATH\"; blocked=(.env .env.local .env.production); for b in \"${blocked[@]}\"; do if [[ \"$f\" == *\"$b\"* ]]; then echo \"BLOCKED: $f is protected\" >&2; exit 1; fi; done'"
          }
        ]
      },
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {"type": "command", "command": "cd backend && ruff check ."},
          {"type": "command", "command": "cd backend && pytest -v"},
          {"type": "command", "command": "bash .claude/hooks/scan-secrets.sh"}
        ]
      },
      {
        "matcher": "TaskOutput",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-nonblocking-taskoutput.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash(rm -r:*)|Bash(rm -f:*)|Bash(git push --force:*)|Bash(git push -f:*)|Bash(git reset --hard:*)|Bash(chmod 777:*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-destructive.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash(psql:*)|Bash(mysql:*)|Bash(drop:*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-destructive.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.npmrc)",
      "Write(~/.pypirc)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cat ~/.aws/*)",
      "Read(~/.docker/config.json)",
      "Read(~/.config/gcloud/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(printenv*)",
      "Bash(env | *)"
    ],
    "allow": [
      "Bash(cd backend && python manage.py runserver:*)",
      "Bash(cd backend && ruff check .:*)",
      "Bash(cd backend && pytest -v:*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Read"
    ]
  }
}
