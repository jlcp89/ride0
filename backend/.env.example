DB_NAME=wingz_db
DB_USER=root
DB_PASSWORD=rootpassword
DB_HOST=db
DB_PORT=3306
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# JWT auth. If unset, JWT_SECRET_KEY falls back to DJANGO_SECRET_KEY.
# Set explicitly in production so secrets can be rotated independently.
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
