						"const json = pm.response.json();",
						"pm.test('has results', () => pm.expect(json.results).to.be.an('array'));",
						"if (json.results.length > 0) {",
						"    pm.test('row shape', () => pm.expect(json.results[0]).to.have.all.keys('month','driver','count'));",
						"}"
					]}}],
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/reports/trips-over-hour/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","reports","trips-over-hour",""] } },
					"response": []
				}
			],
			"description": "Bonus reporting endpoint."
		}
	]
