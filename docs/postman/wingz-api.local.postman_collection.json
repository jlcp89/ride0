{
	"info": {
		"_postman_id": "b8d5e3a2-7f19-4c6b-9e4d-1a3f8c2b5d7e",
		"name": "Wingz Ride API (Local)",
		"description": "Deployed API at http://localhost:8000\n\n## Quick start\n\n1. Import this collection.\n2. Run **Auth → Login**.\n3. Run **Users → List users**.\n4. Run anything else.\n\nNo environment needed. Tokens are managed automatically.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"const token = pm.collectionVariables.get('accessToken');",
					"if (token) {",
					"    pm.request.headers.upsert({",
					"        key: 'Authorization',",
					"        value: 'Bearer ' + token",
					"    });",
					"}"
				]
			}
		}
	],
	"variable": [
		{ "key": "accessToken", "value": "" },
		{ "key": "refreshToken", "value": "" },
		{ "key": "riderId", "value": "" },
		{ "key": "driverId", "value": "" },
		{ "key": "newRideId", "value": "" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.request.headers.remove('Authorization');"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test('has access_token', () => pm.expect(json).to.have.property('access_token'));",
									"pm.test('has refresh_token', () => pm.expect(json).to.have.property('refresh_token'));",
									"pm.test('user.role is admin', () => pm.expect(json.user.role).to.eql('admin'));",
									"pm.collectionVariables.set('accessToken', json.access_token);",
									"pm.collectionVariables.set('refreshToken', json.refresh_token);"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@wingz.com\",\n  \"password\": \"adminpass123\"\n}" },
						"url": { "raw": "http://localhost:8000/api/auth/login/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","auth","login",""] }
					},
					"response": []
				},
				{
					"name": "Refresh token",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.request.headers.remove('Authorization');",
									"const rt = pm.collectionVariables.get('refreshToken');",
									"if (rt) { pm.request.body.raw = JSON.stringify({ refresh_token: rt }); }"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test('has access_token', () => pm.expect(json).to.have.property('access_token'));",
									"pm.collectionVariables.set('accessToken', json.access_token);"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}" },
						"url": { "raw": "http://localhost:8000/api/auth/refresh/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","auth","refresh",""] }
					},
					"response": []
				},
				{
					"name": "Current user (me)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status 200', () => pm.response.to.have.status(200));",
									"pm.test('role is admin', () => pm.expect(pm.response.json().role).to.eql('admin'));"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "http://localhost:8000/api/auth/me/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","auth","me",""] }
					},
					"response": []
				},
				{
					"name": "Logout",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status 204', () => pm.response.to.have.status(204));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": { "raw": "http://localhost:8000/api/auth/logout/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","auth","logout",""] }
					},
					"response": []
				}
			],
			"description": "Run **Login** first. Tokens are saved and injected into all subsequent requests automatically."
		},
		{
			"name": "Rides — Read",
			"item": [
				{
					"name": "List — defaults",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('status 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('has pagination envelope', () => pm.expect(json).to.have.all.keys('count','next','previous','results'));",
						"pm.test('results is array', () => pm.expect(json.results).to.be.an('array'));",
						"if (json.results.length > 0) {",
						"    const r = json.results[0];",
						"    pm.test('nested rider', () => pm.expect(r.id_rider).to.be.an('object'));",
						"    pm.test('nested driver', () => pm.expect(r.id_driver).to.be.an('object'));",
						"    pm.test('todays_ride_events', () => pm.expect(r.todays_ride_events).to.be.an('array'));",
						"}"
					]}}],
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/rides/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides",""] } },
					"response": []
				},
				{
					"name": "List — paginated",
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/rides/?page=2&page_size=5", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides",""], "query": [{"key":"page","value":"2"},{"key":"page_size","value":"5"}] } },
					"response": []
				},
				{
					"name": "List — filter by status",
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/rides/?status=en-route&page_size=100", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides",""], "query": [{"key":"status","value":"en-route","description":"Valid: to-pickup, en-route, dropoff"},{"key":"page_size","value":"100"}] } },
					"response": []
				},
				{
					"name": "List — filter by rider email",
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/rides/?rider_email=alice@example.com&page_size=100", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides",""], "query": [{"key":"rider_email","value":"alice@example.com"},{"key":"page_size","value":"100"}] } },
					"response": []
				},
				{
					"name": "List — combined filters",
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/rides/?status=dropoff&rider_email=alice@example.com&page_size=100", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides",""], "query": [{"key":"status","value":"dropoff"},{"key":"rider_email","value":"alice@example.com"},{"key":"page_size","value":"100"}] } },
					"response": []
				},
				{
					"name": "List — sort by pickup_time",
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/rides/?sort_by=pickup_time&page_size=100", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides",""], "query": [{"key":"sort_by","value":"pickup_time"},{"key":"page_size","value":"100"}] } },
					"response": []
				},
				{
					"name": "List — sort by distance",
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/rides/?sort_by=distance&latitude=14.5995&longitude=-90.5131&page_size=100", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides",""], "query": [{"key":"sort_by","value":"distance"},{"key":"latitude","value":"14.5995"},{"key":"longitude","value":"-90.5131"},{"key":"page_size","value":"100"}] } },
					"response": []
				},
				{
					"name": "List — distance missing lat/lng (400)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('status 400', () => pm.response.to.have.status(400));",
						"pm.test('error message', () => pm.expect(pm.response.json().error).to.match(/latitude and longitude are required/i));"
					]}}],
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/rides/?sort_by=distance", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides",""], "query": [{"key":"sort_by","value":"distance"}] } },
					"response": []
				},
				{
					"name": "Retrieve ride by id",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('status 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('has id_ride', () => pm.expect(json).to.have.property('id_ride'));",
						"pm.test('nested rider', () => pm.expect(json.id_rider).to.be.an('object'));",
						"pm.test('nested driver', () => pm.expect(json.id_driver).to.be.an('object'));",
						"pm.test('todays_ride_events', () => pm.expect(json.todays_ride_events).to.be.an('array'));"
					]}}],
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/rides/1/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides","1",""] } },
					"response": []
				}
			],
			"description": "Read operations on /api/rides/."
		},
		{
			"name": "Rides — Write",
			"item": [
				{
					"name": "Create ride",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('status 201', () => pm.response.to.have.status(201));",
						"const json = pm.response.json();",
						"pm.test('has id_ride', () => pm.expect(json).to.have.property('id_ride'));",
						"pm.test('status matches', () => pm.expect(json.status).to.eql('to-pickup'));",
						"pm.test('rider is object', () => pm.expect(json.id_rider).to.be.an('object'));",
						"pm.test('driver is object', () => pm.expect(json.id_driver).to.be.an('object'));",
						"pm.test('rider != driver', () => pm.expect(json.id_rider.id_user).to.not.eql(json.id_driver.id_user));",
						"pm.collectionVariables.set('newRideId', json.id_ride);"
					]}}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"status\": \"to-pickup\",\n  \"id_rider\": {{riderId}},\n  \"id_driver\": {{driverId}},\n  \"pickup_latitude\": 14.6349,\n  \"pickup_longitude\": -90.5069,\n  \"dropoff_latitude\": 14.5995,\n  \"dropoff_longitude\": -90.5131,\n  \"pickup_time\": \"2026-06-15T16:00:00Z\"\n}" },
						"url": { "raw": "http://localhost:8000/api/rides/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides",""] },
						"description": "Run Users → List users first to populate {{riderId}} and {{driverId}}."
					},
					"response": []
				},
				{
					"name": "Update ride (PATCH)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('status 200', () => pm.response.to.have.status(200));",
						"pm.test('status updated', () => pm.expect(pm.response.json().status).to.eql('en-route'));"
					]}}],
					"request": {
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"status\": \"en-route\",\n  \"pickup_latitude\": 14.6400,\n  \"pickup_longitude\": -90.5100\n}" },
						"url": { "raw": "http://localhost:8000/api/rides/{{newRideId}}/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides","{{newRideId}}",""] }
					},
					"response": []
				},
				{
					"name": "Update ride — validation error (400)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('status 400', () => pm.response.to.have.status(400));",
						"pm.test('has error', () => pm.expect(pm.response.json()).to.have.property('error'));"
					]}}],
					"request": {
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"status\": \"invalid-status\",\n  \"pickup_latitude\": 999\n}" },
						"url": { "raw": "http://localhost:8000/api/rides/{{newRideId}}/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides","{{newRideId}}",""] }
					},
					"response": []
				},
				{
					"name": "Delete ride",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('status 204', () => pm.response.to.have.status(204));"
					]}}],
					"request": {
						"method": "DELETE",
						"header": [],
						"url": { "raw": "http://localhost:8000/api/rides/{{newRideId}}/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides","{{newRideId}}",""] }
					},
					"response": []
				},
				{
					"name": "Verify deletion (404)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('status 404', () => pm.response.to.have.status(404));"
					]}}],
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "http://localhost:8000/api/rides/{{newRideId}}/", "protocol": "http", "host": ["localhost:8000"], "path": ["api","rides","{{newRideId}}",""] }
					},
					"response": []
				}
			],
			"description": "Run top-to-bottom: Create → Update → Validation error → Delete → Verify 404."
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "List users",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('status 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('has results', () => pm.expect(json.results).to.be.an('array'));",
						"pm.test('password not exposed', () => { if (json.results.length > 0) pm.expect(json.results[0]).to.not.have.property('password'); });",
						"const riders = json.results.filter(u => u.role === 'rider');",
						"const drivers = json.results.filter(u => u.role === 'driver');",
						"if (riders.length > 0) pm.collectionVariables.set('riderId', riders[0].id_user);",
						"if (drivers.length > 0) pm.collectionVariables.set('driverId', drivers[0].id_user);"
					]}}],
					"request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:8000/api/users/?page_size=100", "protocol": "http", "host": ["localhost:8000"], "path": ["api","users",""], "query": [{"key":"page_size","value":"100"}] } },
					"response": []
				}
			],
			"description": "Run List users before creating rides — it saves rider/driver ids."
		},
		{
			"name": "Reports",
			"item": [
				{
					"name": "Trips over 1 hour",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
